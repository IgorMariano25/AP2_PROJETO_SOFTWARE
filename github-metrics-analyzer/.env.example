# Copie este arquivo para ".env" e preencha com o seu token.
# O arquivo ".env" esta no .gitignore e NUNCA deve ser commitado.
#
# Gere um token em: https://github.com/settings/tokens
# Escopo minimo recomendado: "public_repo" (apenas leitura de repos publicos).

GITHUB_TOKEN=ghp_cole_seu_token_aqui
